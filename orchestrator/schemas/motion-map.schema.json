{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MotionMap",
  "type": "object",
  "properties": {
    "page": { "type": "string" },
    "breakpoints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "interactions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["load", "hover", "scroll", "cursor", "transition", "svg-path"]
          },
          "target": { "type": "string" },
          "trigger": { "type": "string" },
          "start": { "type": "string" },
          "end": { "type": "string" },
          "scrub": { "type": ["boolean", "number"] },
          "pin": { "type": "boolean" },
          "duration": { "type": "number" },
          "ease": { "type": "string" },
          "props": { "type": "object" },
          "mobileFallback": { "type": "string" }
        },
        "required": ["id", "kind", "target", "trigger"]
      }
    }
  },
  "required": ["page", "interactions"]
}
